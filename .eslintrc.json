{
    "env": {
        "browser": true,
        "node": true,
        "es2021": true
    },
    "extends": ["eslint:recommended", "plugin:react/recommended"],
    "overrides": [],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": ["react"],
    "rules": {
        "indent": ["error", 4],
        "linebreak-style": ["error", "windows"],
        "no-async-promise-executor": "off",
        "quotes": ["error", "double"],
        "react/prop-types": [0],
        "react/jsx-uses-react": "off",
        "react/react-in-jsx-scope": "off",
        "semi": ["error", "always"]
    }
}
